{
  "type": "https://eips.ethereum.org/EIPS/eip-8004#registration-v1",
  "name": "Qevor Mantle Agent Wallet",
  "description": "An ERC-8004 agent wallet for policy-gated payments on Mantle. It plans payment operations, checks safety rules, executes approved or policy-allowed payouts, and records verifiable agent decisions.",
  "homepage": "https://qevor.xyz",
  "image": "https://qevor.xyz/qevor-logo.png",
  "active": true,
  "x402Support": false,
  "registrations": [
    {
      "chainId": 5000,
      "agentId": 1,
      "agentRegistry": "eip155:5000:0x6883610c14cBd2F6E975DC546747B1c9FF5C4fc1",
      "agentWallet": "eip155:5000:0xB99bc321AB360AbD0A87E0B2E1EB8df364851D60"
    }
  ],
  "supportedTrust": [
    "reputation",
    "crypto-economic"
  ],
  "chains": [
    {
      "chainId": 5000,
      "name": "Mantle Mainnet",
      "nativeToken": "MNT"
    },
    {
      "chainId": 5003,
      "name": "Mantle Sepolia",
      "nativeToken": "MNT"
    }
  ],
  "capabilities": [
    "payment-request",
    "batch-payment",
    "recurring-payment",
    "payment-safety-review",
    "policy-enforcement",
    "byreal-compatible-preflight"
  ],
  "controls": {
    "defaultApproval": "human",
    "autonomousMode": "policy-gated",
    "riskChecks": [
      "duplicate-recipient",
      "invalid-address",
      "wrong-chain",
      "insufficient-balance",
      "daily-limit",
      "max-payment"
    ]
  },
  "services": [
    {
      "name": "web",
      "endpoint": "https://qevor.xyz/agents"
    },
    {
      "name": "MCP",
      "endpoint": "https://api.qevor.xyz/mcp",
      "version": "2025-06-18"
    },
    {
      "name": "OASF",
      "endpoint": "https://api.qevor.xyz/.well-known/qevor-agent-skills.json",
      "version": "0.8",
      "skills": [
        "payment-request",
        "batch-payment",
        "recurring-payment",
        "payment-safety-review",
        "policy-enforcement",
        "byreal-compatible-preflight"
      ],
      "domains": [
        "payments",
        "agent-wallets",
        "mantle"
      ]
    }
  ]
}
