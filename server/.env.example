# Qevor server (executor + API) environment.
# Copy to server/.env and fill in.

# --- Supabase ---
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# --- Arc Testnet ---
ARC_RPC_URL=https://rpc.testnet.arc.network
ARC_CHAIN_ID=5042002

# --- Circle CLI (executor uses operator session) ---
# Operator must run `circle wallet login` interactively; the executor reads
# the resulting session from the Circle CLI config directory.
CIRCLE_CLI_CONFIG_DIR=
CIRCLE_CLI_HOME=
CIRCLE_ACCEPT_TERMS=1

# --- NOTARY attestation gating ---
# These names MUST match what server/src/executor/batch-processor.ts reads.
# Leaving them blank keeps the verifier in fail-closed mode (rpc_unavailable)
# for any wallet with attestation_mode != 'off'.
NOTARY_ATTESTATION_REGISTRY=
NOTARY_IDENTITY_REGISTRY=
NOTARY_ARC_RPC_URL=https://rpc.testnet.arc.network
NOTARY_ARC_CHAIN_ID=5042002
NOTARY_EIP712_DOMAIN_NAME=NOTARY
NOTARY_EIP712_DOMAIN_VERSION=1
NOTARY_RPC_TIMEOUT_MS=8000
NOTARY_RPC_RETRIES=2

# Outbound settlement webhook to NOTARY. Header and secret must match
# notary/services/qevorpay.py::verify_webhook on the NOTARY side and the
# QEVORPAY_WEBHOOK_SECRET / QEVORPAY_WEBHOOK_SIGNATURE_HEADER values there.
NOTARY_WEBHOOK_URL=
NOTARY_WEBHOOK_SECRET=
NOTARY_WEBHOOK_SIGNATURE_HEADER=x-signature
NOTARY_WEBHOOK_TIMEOUT_MS=10000

# --- Logging ---
LOG_LEVEL=info
